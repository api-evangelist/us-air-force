{
  "@context": {
    "@vocab": "https://schema.org/",
    "dcat": "http://www.w3.org/ns/dcat#",
    "dct": "http://purl.org/dc/terms/",
    "foaf": "http://xmlns.com/foaf/0.1/",
    "gov": "https://www.w3.org/ns/gov#",
    "xsd": "http://www.w3.org/2001/XMLSchema#",

    "usaf": "https://www.af.mil/vocab/",

    "GovernmentOrganization": "GovernmentOrganization",
    "Dataset": "dcat:Dataset",
    "DataCatalog": "DataCatalog",
    "DataDownload": "DataDownload",

    "id": "@id",
    "title": "dct:title",
    "description": "dct:description",
    "publisher": "dct:publisher",
    "keyword": "dcat:keyword",
    "theme": "dcat:theme",
    "modified": {
      "@id": "dct:modified",
      "@type": "xsd:dateTime"
    },
    "issued": {
      "@id": "dct:issued",
      "@type": "xsd:date"
    },
    "accrualPeriodicity": "dct:accrualPeriodicity",
    "accessLevel": "dct:accessRights",
    "license": "dct:license",
    "distribution": "dcat:distribution",
    "downloadURL": "dcat:downloadURL",
    "mediaType": "dcat:mediaType",
    "format": "dct:format",
    "spatial": "dct:spatial",
    "temporal": "dct:temporal",
    "contactPoint": "dcat:contactPoint",

    "AirForceProgram": "usaf:AirForceProgram",
    "MilitaryInstallation": "usaf:MilitaryInstallation",
    "AirForceBase": "usaf:AirForceBase",
    "AirForcePersonnel": "usaf:AirForcePersonnel",
    "AircraftFleet": "usaf:AircraftFleet",
    "MilitaryUnit": "usaf:MilitaryUnit",
    "ResearchProgram": "usaf:ResearchProgram",

    "name": "name",
    "url": "url",
    "email": "email",
    "fn": "foaf:name",
    "hasEmail": "foaf:mbox"
  }
}
